# ==========================
# Конфигурация
# ==========================
# WiFi
WIFI_SSID = "ВАШ_WIFI_SSID"
WIFI_PASSWORD = "ВАШ_WIFI_PASSWORD"

# MQTT
MQTT_BROKER = "broker.hivemq.com"
MQTT_PORT = 1883
MQTT_CLIENT_ID = "rpi_pico_w_greenhouse"

# Топики MQTT для обмена данными и командами
MQTT_TOPICS = {
    "temperature": "greenhouse/temperature",
    "humidity": "greenhouse/humidity",
    "co2": "greenhouse/co2",
    "soil_moisture": "greenhouse/soil_moisture",
    "light": "greenhouse/light",
    "pump_cmd": "greenhouse/pump/cmd",
    "vent_cmd": "greenhouse/vent/cmd",
}

# GPIO распиновка
PIN_DHT22 = 15
PIN_SOIL_MOISTURE_ADC = 26
PIN_LIGHT_ADC = 27
PIN_CO2_ADC = 28
PIN_RELAY_PUMP = 16
PIN_RELAY_VENT = 20

# ИКП дисплея (например, I2C LCD)
I2C_SCL_PIN = 5
I2C_SDA_PIN = 4
I2C_ADDR = 0x27  # или 0x3F

# Пороги автоматизации
SOIL_WATER_LOW = 30      # %
SOIL_WATER_HIGH = 70     # %
TEMP_HIGH_THRESHOLD = 30 # °C
TEMP_LOW_THRESHOLD = 20  # °C

# Время задержки между циклами
READ_INTERVAL = 30  # секунд

# ==========================
# Классы и функции
# ==========================

class WiFi:
    """Класс для подключения к WiFi"""
    def __init__(self, ssid, password):
        self.ssid = ssid
        self.password = password
        self.station = network.WLAN(network.STA_IF)

    def connect(self):
        print("Подключение к WiFi...")
        self.station.active(True)
        self.station.connect(self.ssid, self.password)
        while not self.station.isconnected():
            print(".", end="")
            time.sleep(1)
        print(f"\nПодключено: {self.station.ifconfig()}")


class MQTTManager:
    """Класс для управления MQTT соединением и публикацией данных"""
    def __init__(self, broker, port, client_id):
        self.client = MQTTClient(client_id, broker, port)
        self.connected = False

    def connect(self):
        try:
            self.client.connect()
            self.connected = True
            print("MQTT подключено")
        except Exception as e:
            print(f"Ошибка MQTT: {e}")
            self.connected = False

    def publish(self, topic, msg):
        if self.connected:
            try:
                self.client.publish(topic, str(msg))
            except Exception as e:
                print(f"Ошибка публикации: {e}")

    def subscribe(self, topic, callback):
        if self.connected:
            try:
                self.client.set_callback(callback)
                self.client.subscribe(topic)
            except Exception as e:
                print(f"Ошибка подписки: {e}")

    def check(self):
        if self.connected:
            try:
                self.client.check_msg()
            except Exception as e:
                print(f"Ошибка проверки сообщений: {e}")

    def disconnect(self):
        if self.connected:
            try:
                self.client.disconnect()
            except Exception as e:
                print(f"Ошибка отключения: {e}")

